{
  "name": "cuenote-desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "concurrently -k \"tsc -p tsconfig.electron.json --watch\" \"wait-on file:dist/main/electron-main.js && electron dist/main/electron-main.js\"",
    "dev": "concurrently -k \"pnpm run dev:vite\" \"pnpm run dev:electron\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codemirror/basic-setup": "^0.20.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^8.2.2",
    "electron": "^39.2.7",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4",
    "wait-on": "^9.0.3"
  }
}
